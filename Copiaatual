    <style>
        * { box-sizing: border-box; margin: 0; padding: 0; font-family: 'Segoe UI', Arial, sans-serif; }
        body { background-color: #f0f4f8; color: #1e293b; padding: 20px; display: flex; flex-direction: column; align-items: center; }
        
        .card { background: white; border-radius: 12px; padding: 22px; box-shadow: 0 4px 6px rgba(0,0,0,0.05); border: 1px solid #e2e8f0; display: flex; flex-direction: column; gap: 15px; width: 100%; max-width: 600px; margin-bottom: 20px; }
        .card h2 { font-size: 18px; color: #0f172a; border-bottom: 2px solid #f1f5f9; padding-bottom: 8px; display: flex; align-items: center; gap: 8px; }
        
        .form-group { display: flex; flex-direction: column; gap: 6px; width: 100%; }
        .form-group label { font-size: 13px; font-weight: 600; color: #475569; }
        
        input[type="text"], input[type="number"] { width: 100%; padding: 10px; border: 1px solid #cbd5e1; border-radius: 8px; font-size: 14px; outline: none; }
        input[type="text"]:focus { border-color: #3b82f6; }
        
        .numeros-sorte-container { display: flex; gap: 10px; justify-content: center; margin: 5px 0; }
        .input-sorte { width: 60px !important; text-align: center; font-size: 16px; font-weight: bold; }
        
        button { padding: 12px; font-size: 14px; font-weight: 600; border: none; border-radius: 8px; cursor: pointer; transition: all 0.2s; display: flex; align-items: center; justify-content: center; gap: 8px; width: 100%; }
        .btn-blue { background-color: #3b82f6; color: white; }
        .btn-blue:hover { background-color: #2563eb; }
        .btn-green { background-color: #10b981; color: white; font-size: 16px; }
        .btn-green:hover { background-color: #059669; }
        .btn-purple { background-color: #8b5cf6; color: white; }
        .btn-purple:hover { background-color: #7c3aed; }
        
        .btn-live-blue { 
            background-color: #2563eb; 
            color: white; 
            font-size: 15px; 
            text-decoration: none; 
            display: flex; 
            align-items: center; 
            justify-content: center; 
            border-radius: 8px; 
            padding: 12px; 
            font-weight: bold; 
            width: 100%;
            margin-bottom: 15px;
            box-shadow: 0 0 0 0 rgba(37, 99, 235, 0.7);
            animation: pulse-blue 1.8s infinite cubic-bezier(0.66, 0, 0, 1);
        }
        @keyframes pulse-blue {
            to { box-shadow: 0 0 0 12px rgba(37, 99, 235, 0); }
        }

        /* ===== ANIMAÇÃO DO BONECO (MASCOTE) ===== */
        .boneco-mascote {
            cursor: pointer;
            transform-origin: center bottom;
            filter: drop-shadow(0 6px 10px rgba(0,0,0,0.18));
            animation: bonecoEntrada 0.8s ease-out, bonecoFloat 3.2s ease-in-out infinite 0.8s;
        }
        @keyframes bonecoEntrada {
            0% { opacity: 0; transform: scale(0.4) translateY(50px) rotate(-8deg); }
            60% { opacity: 1; transform: scale(1.1) translateY(-8px) rotate(3deg); }
            100% { opacity: 1; transform: scale(1) translateY(0) rotate(0deg); }
        }
        @keyframes bonecoFloat {
            0%, 100% { transform: translateY(0) rotate(-2deg); }
            50% { transform: translateY(-10px) rotate(2deg); }
        }
        .boneco-mascote.boneco-pulo {
            animation: bonecoPulo 0.6s ease;
        }
        @keyframes bonecoPulo {
            0% { transform: scale(1) rotate(0deg); }
            30% { transform: scale(1.25) rotate(-12deg) translateY(-14px); }
            60% { transform: scale(0.92) rotate(8deg) translateY(2px); }
            100% { transform: scale(1) rotate(0deg) translateY(0); }
        }
        .boneco-mascote.boneco-vencedor {
            animation: bonecoComemoracao 0.9s ease-in-out infinite;
        }
        @keyframes bonecoComemoracao {
            0%, 100% { transform: translateY(0) rotate(-6deg) scale(1); }
            25% { transform: translateY(-18px) rotate(6deg) scale(1.08); }
            50% { transform: translateY(0) rotate(-6deg) scale(1); }
            75% { transform: translateY(-18px) rotate(6deg) scale(1.08); }
        }

        .cartela-layout { display: grid; grid-template-columns: repeat(5, 1fr); gap: 8px; margin: 15px 0; justify-content: center; }
        .num-bola { background-color: #f1f5f9; border: 2px solid #cbd5e1; color: #334155; font-size: 18px; font-weight: bold; height: 45px; border-radius: 50%; display: flex; align-items: center; justify-content: center; transition: all 0.3s; }
        
        .num-bola.marcado { 
            background: radial-gradient(circle, #39FF14, #04b304); 
            color: #000000; 
            border-color: #028002; 
            transform: scale(1.05); 
            box-shadow: 0 3px 6px rgba(57, 255, 20, 0.4); 
        }
        
        .bola-grande { background: linear-gradient(135deg, #f59e0b, #d97706); color: white; width: 70px; height: 70px; font-size: 32px; font-weight: 700; border-radius: 50%; display: flex; align-items: center; justify-content: center; margin: 10px auto; box-shadow: 0 4px 10px rgba(217,119,6,0.3); }
        .historico-grid { display: flex; flex-wrap: wrap; gap: 5px; justify-content: center; margin-top: 10px; max-height: 80px; overflow-y: auto; padding: 2px; }
        
        .bola-mini { background-color: #39FF14; color: #000000; width: 26px; height: 26px; font-size: 11px; font-weight: bold; border-radius: 50%; display: flex; align-items: center; justify-content: center; }

        .lista-linhas-compacta { max-height: 200px; overflow-y: auto; display: flex; flex-direction: column; gap: 6px; }
        .item-lista-pela-boa { display: flex; justify-content: space-between; align-items: center; padding: 8px 12px; border-bottom: 1px solid #e2e8f0; font-size: 13px; background: #fff7ed; border-radius: 6px; border-left: 4px solid #f97316; }
        
        .info-header-box { display: flex; justify-content: space-between; width: 100%; max-width: 600px; margin-bottom: 12px; background: #fff; padding: 12px 15px; border-radius: 10px; border: 1px solid #e2e8f0; font-weight: bold; font-size: 15px; }
        .alerta-bloqueio { background: #fff3cd; border: 2px dashed #ffc107; color: #856404; padding: 12px; text-align: center; border-radius: 8px; width: 100%; font-weight: bold; font-size: 14px; margin-bottom: 15px; display: none; }
        .alerta-vencedor { background: #fef2f2; border: 3px dashed #ef4444; color: #991b1b; padding: 15px; border-radius: 8px; text-align: center; font-weight: bold; margin-bottom: 15px; display: none; animation: pulse 1.5s infinite; }
        @keyframes pulse { 0% { transform: scale(1); } 50% { transform: scale(1.02); } 100% { transform: scale(1); } }

        /* ===== BILHETE DO VENCEDOR (grade 3x5, 15 números) ===== */
        .wrapper-bilhetes-vencedores { display: flex; flex-direction: column; gap: 14px; margin-top: 10px; text-align: left; }
        .bilhete-vencedor { background: #fff; border: 3px solid #f59e0b; border-radius: 10px; padding: 16px; }
        .bilhete-vencedor.meu-bilhete { border-color: #16a34a; background: #f0fdf4; }
        .bilhete-vencedor .bilhete-titulo { font-size: 13px; font-weight: 800; color: #b45309; text-transform: uppercase; letter-spacing: 0.5px; display: block; margin-bottom: 4px; }
        .bilhete-vencedor.meu-bilhete .bilhete-titulo { color: #15803d; }
        .bilhete-vencedor .bilhete-nome { font-size: 17px; font-weight: 800; color: #111; }
        .bilhete-vencedor .bilhete-info { font-size: 13px; color: #475569; margin-bottom: 10px; }
        .bilhete-grade { display: grid; grid-template-columns: repeat(5, 1fr); grid-template-rows: repeat(3, 1fr); gap: 6px; }
        .bilhete-grade .bilhete-num { background: radial-gradient(circle, #39FF14, #04b304); color: #000; font-weight: bold; font-size: 16px; height: 42px; border-radius: 8px; display: flex; align-items: center; justify-content: center; }
        
        .area-pix { background: #f0fdf4; border: 1px dashed #16a34a; padding: 15px; border-radius: 8px; margin-top: 10px; display: none; flex-direction: column; gap: 10px; text-align: center; }
        .contador-bilhetes { text-align: center; font-size: 13px; color: #065f46; font-weight: 600; background: #ecfdf5; border-radius: 6px; padding: 6px 12px; margin-bottom: 10px; border: 1px solid #a7f3d0; }

        /* Estilo da aba de cartelas agrupadas */
        .wrapper-minhas-cartelas { display: flex; flex-direction: column; gap: 20px; width: 100%; }
        .bloco-cartela-individual { background: #fff; border: 2px solid #e2e8f0; border-radius: 10px; padding: 15px; position: relative; }
        .bloco-cartela-individual.paga { border-color: #10b981; background: #fcfdfd; }
        .bloco-cartela-individual.pendente { border-color: #f59e0b; background: #ffffff; }
        .badge-status { position: absolute; top: 12px; right: 12px; font-size: 11px; font-weight: bold; padding: 3px 8px; border-radius: 12px; text-transform: uppercase; }
        .badge-status.paga { background: #dcfce7; color: #15803d; }
        .badge-status.pendente { background: #fef3c7; color: #b45309; }
    </style>
</head>

