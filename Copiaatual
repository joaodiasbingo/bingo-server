});

db.ref('estoque').on('value', snap => { estoqueCompleto = snap.val() || {}; });

db.ref('participantes').on('value', snap => {
    participantesAtivos = [];
    let dados = snap.val();
    
    if(!dados) {
        participantesAtivos = [];
        cartelaSelecionada = null;
        meusBiletesReservados = [];
        localStorage.removeItem('jdbingo_meusBiletes');
        atualizarContadorBilhetes();
        document.getElementById('secaoMinhaCartela').style.display = 'none';
        if(document.getElementById('secaoCompraCartela') && statusAtualJogo === 'aberto') document.getElementById('secaoCompraCartela').style.display = 'flex';
        atualizarTelas();
        return;
    }

    snap.forEach(c => { 
        let obj = c.val();
        if(obj) participantesAtivos.push(obj);
    });

    let IDsValidos = participantesAtivos.map(p => parseInt(p.id));
    meusBiletesReservados = meusBiletesReservados.filter(id => IDsValidos.includes(parseInt(id)));
    localStorage.setItem('jdbingo_meusBiletes', JSON.stringify(meusBiletesReservados));

    atualizarContadorBilhetes();
    atualizarTelas();
});

function atualizarTelas() {
    renderizarMultiplasCartelasCliente();
    calcularPelaBoaCliente();
}

function executarBuscaInteligenteBolasSorte() {
    if(statusAtualJogo !== 'aberto') {
        return alert("🔒 O administrador fechou as vendas para este sorteio!");
    }

    let nome = document.getElementById('cliNome').value.trim();
    if(!nome) return alert("Por favor, preencha seu nome antes de buscar!");

    let n1 = parseInt(document.getElementById('sorte1').value);
    let n2 = parseInt(document.getElementById('sorte2').value);
    let n3 = parseInt(document.getElementById('sorte3').value);

    if(isNaN(n1) || isNaN(n2) || isNaN(n3)) return alert("Preencha as 3 dezenas da sorte para filtrar a melhor combinação!");

    let desejados = [n1, n2, n3];
    let livres = Object.values(estoqueCompleto).filter(c => c && c.status === 'livre');

    if(livres.length === 0) return alert("Não há mais combinações livres neste estoque!");

    let grupo3 = [], grupo2 = [], grupo1 = [];

    livres.forEach(cartela => {
        if (!cartela || !cartela.numeros) return;
        
        let cNums = [];
        if (Array.isArray(cartela.numeros)) {
            cNums = cartela.numeros.slice(0, 15).map(n => parseInt(n));
        } else if (typeof cartela.numeros === 'string') {
            cNums = cartela.numeros.split(',').map(n => parseInt(n.trim()));
        }

        let batidas = cNums.filter(n => desejados.includes(n)).length;
        
        if(batidas === 3) grupo3.push(cartela);
        else if(batidas === 2) grupo2.push(cartela);
        else if(batidas === 1) grupo1.push(cartela);
    });

    if(grupo3.length > 0) {
        cartelaSelecionada = grupo3[Math.floor(Math.random() * grupo3.length)];
        aplicarCartelaEscolhida();
    } else if(grupo2.length > 0) {
        let aceita = confirm("Não encontramos nenhuma combinação com os 3 números exatos nas dezenas livres, mas encontramos opções com 2 deles! Deseja visualizar esta sugestão?");
        if(aceita) {
            cartelaSelecionada = grupo2[Math.floor(Math.random() * grupo2.length)];
            aplicarCartelaEscolhida();
        }
    } else if(grupo1.length > 0) {
        let aceita = confirm("Seus 3 números combinados não estão livres juntos. Deseja aceitar uma cartela contendo 1 de seus números da sorte?");
        if(aceita) {
            cartelaSelecionada = grupo1[Math.floor(Math.random() * grupo1.length)];
            aplicarCartelaEscolhida();
        }
    } else {
        alert("Nenhuma combinação contendo seus números da sorte está livre. Selecionamos uma excelente cartela aleatória com 15 números para você concorrer!");
        cartelaSelecionada = livres[Math.floor(Math.random() * livres.length)];
        aplicarCartelaEscolhida();
    }
}

function aplicarCartelaEscolhida() {
    if(!cartelaSelecionada) return;
    document.getElementById('secaoCompraCartela').style.display = 'none';
    document.getElementById('secaoMinhaCartela').style.display = 'flex';
    document.getElementById('blocoAcoesIniciaisCompra').style.display = 'block';
    document.getElementById('blocoCanaisPagamento').style.display = 'none';
    renderizarMultiplasCartelasCliente();
}

function iniciarNovaBusca() {
    if(statusAtualJogo !== 'aberto') {
        return alert("🔒 Desculpe, o administrador já fechou as reservas para este sorteio. Não é possível comprar mais cartelas.");
    }

    let tel = document.getElementById('cliTelefone').value.trim();
    if(meusBiletesReservados.length >= LIMITE_CARTELAS_POR_TELEFONE) {
        return alert(`⚠️ Você já atingiu o limite máximo de ${LIMITE_CARTELAS_POR_TELEFONE} cartelas nesta rodada!`);
    }
    cartelaSelecionada = null;
    document.getElementById('sorte1').value = '';
    document.getElementById('sorte2').value = '';
    document.getElementById('sorte3').value = '';
    document.getElementById('secaoMinhaCartela').style.display = meusBiletesReservados.length > 0 ? 'flex' : 'none';
    document.getElementById('secaoCompraCartela').style.display = 'flex';
}

function renderizarMultiplasCartelasCliente() {
    let container = document.getElementById('containerMultiplasCartelas');
    if(!container) return;
    container.innerHTML = "";

    let listaExibicao = [];

    if(cartelaSelecionada && cartelaSelecionada.numeros) {
        let numsProntos = Array.isArray(cartelaSelecionada.numeros) ? cartelaSelecionada.numeros.slice(0, 15) : cartelaSelecionada.numeros.split(',').map(n => n.trim());
        listaExibicao.push({
            id: cartelaSelecionada.id,
            numeros: numsProntos,
            status: 'analise'
        });
    }

    meusBiletesReservados.forEach(idBilete => {
        let encontrado = participantesAtivos.find(p => parseInt(p.id) === parseInt(idBilete));
        if(encontrado) {
            listaExibicao.push(encontrado);
        }
    });

    if(listaExibicao.length === 0) {
        document.getElementById('secaoMinhaCartela').style.display = 'none';
        return;
    } else {
        document.getElementById('secaoMinhaCartela').style.display = 'flex';
    }

    listaExibicao.forEach(cartela => {
        if(!cartela || !cartela.numeros) return;
        let bloco = document.createElement('div');
        let statusLimpo = cartela.status || 'pendente';
        bloco.className = `bloco-cartela-individual ${statusLimpo}`;

        let txtStatus = statusLimpo === 'analise' ? 'RESERVANDO' : statusLimpo;
        let corBadge = statusLimpo === 'paga' ? 'paga' : 'pendente';

        let htmlHeader = `<h3 style="font-size:15px; margin-bottom:5px; color:#1e293b;">🎫 Cartela #${cartela.id}</h3>
                          <span class="badge-status ${corBadge}">${txtStatus}</span>`;
        
        let grid = document.createElement('div');
        grid.className = "cartela-layout";

        let acertados = 0;
        let nNums = Array.isArray(cartela.numeros) ? cartela.numeros.map(n => parseInt(n)) : cartela.numeros.split(',').map(n => parseInt(n.trim()));

        nNums.forEach(num => {
            let bola = document.createElement('div');
            bola.className = "num-bola";
            bola.innerText = num;
            if(bolasSorteadas.includes(num)) {
                bola.className = "num-bola marcado";
                acertados++;
            }
            grid.appendChild(bola);
        });

        let faltam = 15 - acertados;

        bloco.innerHTML = htmlHeader;
        bloco.appendChild(grid);

        let footerInfo = document.createElement('div');
        footerInfo.style = "text-align: center; font-size: 13px; color: #475569; margin-top:5px;";
        footerInfo.innerHTML = `Faltam <span style="font-weight: bold; color: #ef4444; font-size: 15px;">${faltam}</span> números para ganhar!`;
        bloco.appendChild(footerInfo);

        container.appendChild(bloco);
    });
}

function calcularPelaBoaCliente() {
    let container = document.getElementById('listaPelaBoaCliente');
    if(!container) return;
    container.innerHTML = "";
    let ranking = [];

    if(bolasSorteadas.length === 0) {
        container.innerHTML = `<p style="color:#94a3b8; text-align:center; font-size:13px;">Nenhum bilhete próximo do fechamento no momento...</p>`;
        ultimoResumoPelaBoa = { faltando1: 0, faltando2: 0 };
        return;
    }

    participantesAtivos.forEach(p => {
        if(p.status === 'paga' && p.numeros) {
            let nNums = Array.isArray(p.numeros) ? p.numeros.slice(0,15).map(n => parseInt(n)) : p.numeros.split(',').map(n => parseInt(n.trim()));
            let marcados = nNums.filter(n => bolasSorteadas.includes(n)).length;
            let faltando = 15 - marcados;

            if(faltando <= 2 && faltando > 0) {
                ranking.push({ p, faltando });
            }
        }
    });

    ranking.sort((a,b) => a.faltando - b.faltando);

    if(ranking.length === 0) {
        container.innerHTML = `<p style="color:#94a3b8; text-align:center; font-size:13px;">Nenhum bilhete próximo do fechamento no momento...</p>`;
        ultimoResumoPelaBoa = { faltando1: 0, faltando2: 0 };
        return;
    }

    ranking.slice(0, 15).forEach(item => {
        let div = document.createElement('div');
        div.className = "item-lista-pela-boa";
        if(item.faltando === 1) div.style.background = "#ffedd5";
        
        div.innerHTML = `<div><strong>#${item.p.id} - ${item.p.nome}</strong></div>
                         <div style="font-weight:bold; color:${item.faltando === 1 ? '#ea580c' : '#475569'};">Faltam ${item.faltando}</div>`;
        container.appendChild(div);
    });

    let totalFaltando1 = ranking.filter(i => i.faltando === 1).length;
    let totalFaltando2 = ranking.filter(i => i.faltando === 2).length;

    if(!bloqueioVencedorAtivo && (totalFaltando1 !== ultimoResumoPelaBoa.faltando1 || totalFaltando2 !== ultimoResumoPelaBoa.faltando2)) {
        let partes = [];
        if(totalFaltando1 > 0) partes.push(`${totalFaltando1} ${totalFaltando1 === 1 ? 'uma pessoa está' : 'pessoas estão'} faltando apenas 1 número`);
        if(totalFaltando2 > 0) partes.push(`${totalFaltando2} ${totalFaltando2 === 1 ? 'uma pessoa está' : 'pessoas estão'} faltando 2 números`);
        if(partes.length > 0) falarTexto("Atenção! " + partes.join(", e "));
    }
    ultimoResumoPelaBoa = { faltando1: totalFaltando1, faltando2: totalFaltando2 };
}

function finalizarEExibirCanaisPagamento() {
    if(statusAtualJogo !== 'aberto') {
        return alert("🔒 O administrador já encerrou as vendas deste sorteio. Registro cancelado.");
    }

    let nome = document.getElementById('cliNome').value.trim();
    let tel = document.getElementById('cliTelefone').value.trim();
    let end = document.getElementById('cliEndereco').value.trim();

    if(!nome || !tel) return alert("Preencha nome e telefone para validar o registro!");

    let totalJaReservado = contarBiletesPorTelefone(tel);
    if(totalJaReservado >= LIMITE_CARTELAS_POR_TELEFONE) {
        return alert(`⚠️ Este telefone já atingiu o limite máximo de ${LIMITE_CARTELAS_POR_TELEFONE} cartelas nesta rodada!`);
    }

    let idAlvo = cartelaSelecionada.id;
    let nNumsSalvar = Array.isArray(cartelaSelecionada.numeros) ? cartelaSelecionada.numeros.slice(0, 15) : cartelaSelecionada.numeros.split(',').map(n => parseInt(n.trim()));

    db.ref('participantes/' + idAlvo).set({
        id: idAlvo,
        idxEstoque: idAlvo,
        nome: nome,
        telefone: tel,
        endereco: end,
        numeros: nNumsSalvar,
        status: 'pendente'
    }).then(() => {
        alert("✨ Bilhete reservado com sucesso! Efetue o pagamento abaixo para o ADM liberar sua cartela.");

        if(!meusBiletesReservados.includes(idAlvo)){
            meusBiletesReservados.push(idAlvo);
            localStorage.setItem('jdbingo_meusBiletes', JSON.stringify(meusBiletesReservados));
        }
        
        cartelaSelecionada = null; 
        ultimoIdReservado = idAlvo;
        atualizarContadorBilhetes();
        atualizarListenerSaldo();
        
        document.getElementById('blocoAcoesIniciaisCompra').style.display = 'none';
        document.getElementById('blocoCanaisPagamento').style.display = 'flex';
        atualizarBotaoPagarComCredito();
        
        let mensagemWhats = encodeURIComponent(`Olá! Fiz a reserva do bilhete #${idAlvo} no nome de ${nome}. Gostaria de confirmar o pagamento em dinheiro ou enviar o comprovante.`);
        document.getElementById('btnWhatsappLink').onclick = function() {
            window.open(`https://wa.me/5592993154399?text=${mensagemWhats}`, '_blank');
        };

        renderizarMultiplasCartelasCliente();
    });
}

atualizarContadorBilhetes();
