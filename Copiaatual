<script>
let bolasSorteadas = [];
let estoqueCompleto = {};
let cartelaSelecionada = null; 
let participantesAtivos = [];
let bloqueioVencedorAtivo = false;
let meusBiletesReservados = JSON.parse(localStorage.getItem('jdbingo_meusBiletes') || '[]'); 
let ultimoResumoPelaBoa = { faltando1: 0, faltando2: 0 }; 
let statusAtualJogo = 'fechado';
let saldoCreditosAtual = 0;
let precoCartelaAtual = 0;
let ultimoIdReservado = null;

const LIMITE_CARTELAS_POR_TELEFONE = 4;

function falarTexto(texto) {
    if ('speechSynthesis' in window) {
        window.speechSynthesis.cancel();
        let falar = new SpeechSynthesisUtterance(texto);
        falar.lang = 'pt-BR';
        falar.rate = 1.1;
        window.speechSynthesis.speak(falar);
    }
}

// ===== ANIMAÇÃO DO BONECO: clique manual (efeito "pulo") =====
function animarBonecoClique() {
    let el = document.getElementById('bonecoMascote');
    if (!el || el.classList.contains('boneco-vencedor')) return; // não interfere na comemoração de vitória
    el.classList.remove('boneco-pulo');
    void el.offsetWidth; // força reinício da animação
    el.classList.add('boneco-pulo');
    el.addEventListener('animationend', function limpar(e) {
        if (e.animationName === 'bonecoPulo') {
            el.classList.remove('boneco-pulo');
            el.removeEventListener('animationend', limpar);
        }
    });
}

function normalizarTelefone(t) {
    return (t || '').replace(/\D/g, '');
}

function contarBiletesPorTelefone(tel) {
    let alvo = normalizarTelefone(tel);
    if (!alvo) return 0;
    return participantesAtivos.filter(p => normalizarTelefone(p.telefone) === alvo).length;
}

// ===== SISTEMA DE CRÉDITOS =====
let listenerSaldoAtivo = null;

function atualizarListenerSaldo() {
    let tel = normalizarTelefone(document.getElementById('cliTelefone').value);
    if (!tel) return;

    if (listenerSaldoAtivo) {
        db.ref('creditos/' + listenerSaldoAtivo).off();
    }
    listenerSaldoAtivo = tel;

    db.ref('creditos/' + tel).on('value', snap => {
        saldoCreditosAtual = parseFloat(snap.val()) || 0;
        let elSaldo = document.getElementById('txtSaldoCreditos');
        if (elSaldo) elSaldo.innerText = "R$ " + saldoCreditosAtual.toFixed(2).replace('.', ',');
        atualizarBotaoPagarComCredito();
    });
}

function atualizarBotaoPagarComCredito() {
    let bloco = document.getElementById('blocoPagarComCredito');
    if (!bloco) return;
    if (saldoCreditosAtual >= precoCartelaAtual && precoCartelaAtual > 0) {
        document.getElementById('txtSaldoNoPagamento').innerText = "R$ " + saldoCreditosAtual.toFixed(2).replace('.', ',');
        bloco.style.display = 'block';
    } else {
        bloco.style.display = 'none';
    }
}

function solicitarCompraCredito() {
    let nome = document.getElementById('cliNome').value.trim();
    let tel = document.getElementById('cliTelefone').value.trim();
    let valor = parseFloat(document.getElementById('valorComprarCredito').value);

    if (!nome || !tel) return alert("Preencha seu nome e telefone antes de comprar créditos!");
    if (isNaN(valor) || valor <= 0) return alert("Informe um valor válido de crédito!");

    let novaRef = db.ref('solicitacoesCredito').push();
    novaRef.set({
        id: novaRef.key,
        nome: nome,
        telefone: tel,
        valor: valor,
        status: 'pendente',
        criadoEm: Date.now()
    }).then(() => {
        alert(`✨ Solicitação de crédito de R$ ${valor.toFixed(2).replace('.', ',')} registrada! Envie o comprovante do PIX pelo WhatsApp para o ADM liberar seu saldo.`);
        document.getElementById('valorComprarCredito').value = '';
        let msg = encodeURIComponent(`Olá! Quero adicionar R$ ${valor.toFixed(2).replace('.', ',')} de crédito na minha conta (${nome}). Segue o comprovante do PIX.`);
        window.open(`https://wa.me/5592993154399?text=${msg}`, '_blank');
    });
}

function pagarCartelaComCredito() {
    if (!ultimoIdReservado) return;
    if (saldoCreditosAtual < precoCartelaAtual) {
        return alert("Saldo insuficiente para pagar com créditos!");
    }

    let tel = normalizarTelefone(document.getElementById('cliTelefone').value);
    let novoSaldo = saldoCreditosAtual - precoCartelaAtual;

    db.ref('creditos/' + tel).set(novoSaldo);
    db.ref('participantes/' + ultimoIdReservado).update({ status: 'paga', pagoComCredito: true });
    db.ref('estoque/' + ultimoIdReservado).update({ status: 'ocupado' });

    alert("✅ Pagamento feito com seus créditos! Sua cartela já está liberada.");
    document.getElementById('blocoCanaisPagamento').style.display = 'none';
    ultimoIdReservado = null;
    renderizarMultiplasCartelasCliente();
}

function atualizarContadorBilhetes() {
    let el = document.getElementById('txtContadorBilhetes');
    if (el) el.innerText = meusBiletesReservados.length;
    
    let btnMais = document.getElementById('btnComprarMais');
    if(btnMais) {
        if(meusBiletesReservados.length >= LIMITE_CARTELAS_POR_TELEFONE) {
            btnMais.style.display = 'none';
        } else {
            btnMais.style.display = 'flex';
        }
    }
}

db.ref('jogo/preco').on('value', snap => {
    let bruto = (snap.val() || "0").toString().replace(',', '.');
    precoCartelaAtual = parseFloat(bruto) || 0;
    document.getElementById('topClientePreco').innerText = "R$ " + (snap.val() || "0,00");
    atualizarBotaoPagarComCredito();
});
db.ref('jogo/premio').on('value', snap => { document.getElementById('topClientePremio').innerText = snap.val() || "A Definir"; });

db.ref('jogo/status').on('value', snap => {
    statusAtualJogo = snap.val() || 'fechado';
    let secaoCompra = document.getElementById('secaoCompraCartela');
    let telaBloqueio = document.getElementById('telaBloqueioSite');
    
    if(statusAtualJogo === 'aberto') {
        if(telaBloqueio) telaBloqueio.style.display = 'none';
        if(secaoCompra && !cartelaSelecionada && meusBiletesReservados.length < LIMITE_CARTELAS_POR_TELEFONE) secaoCompra.style.display = 'flex';
    } else {
        if(secaoCompra) secaoCompra.style.display = 'none';
        if(telaBloqueio) telaBloqueio.style.display = 'block';
    }
});

db.ref('jogo/bolas').on('value', snap => {
    let dados = snap.val();
    
    if (!dados) {
        bolasSorteadas = [];
        document.getElementById('bolaCliente').innerText = "-";
        document.getElementById('historicoCliente').innerHTML = "";
        atualizarTelas();
        return;
    }

    if (bloqueioVencedorAtivo) return;

    bolasSorteadas = Object.values(dados).map(b => parseInt(b));
    document.getElementById('bolaCliente').innerText = bolasSorteadas.length > 0 ? bolasSorteadas[bolasSorteadas.length - 1] : "-";
    
    let hist = document.getElementById('historicoCliente');
    hist.innerHTML = "";
    bolasSorteadas.forEach(b => {
        let mini = document.createElement('div');
        mini.className = 'bola-mini'; mini.innerText = b; hist.appendChild(mini);
    });

    if(bolasSorteadas.length > 0) {
