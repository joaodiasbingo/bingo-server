            bloco.innerHTML = `
                <span class="bilhete-titulo">${souEuGanhando ? '🎉 Você ganhou! ' : ''}Bilhete Premiado — Cartela #${v.id}</span>
                <div class="bilhete-nome">${v.nome}</div>
                <div class="bilhete-info">📞 ${v.telefone || 'N/A'}</div>
                ${montarGradeBilheteCliente(v.numeros || [])}
            `;
            wrapper.appendChild(bloco);
        });

        if(vencedores.length > 1) {
            let nomes = vencedores.map(v => v.nome).join(', ');
            falarTexto(`Atenção! Deu empate! Temos ${vencedores.length} ganhadores nesta rodada: ${nomes}!`);
        } else {
            let v = vencedores[0];
            falarTexto("Atenção! Temos um ganhador! Parabéns para " + v.nome + ", que fechou a cartela número " + v.id + "!");
        }
