function montarGradeBilheteCliente(numeros) {
    let nums = numeros.map(n => parseInt(n));
    let celulas = nums.map(n => `<div class="bilhete-num">${n}</div>`).join('');
    return `<div class="bilhete-grade">${celulas}</div>`;
}

db.ref('jogo/vencedores').on('value', snap => {
    let dados = snap.val();
    let vencedores = dados ? Object.values(dados) : [];
    let box = document.getElementById('boxVencedorCliente');
    let boneco = document.getElementById('bonecoMascote');
    let titulo = document.getElementById('txtTituloVencedorCliente');
    let wrapper = document.getElementById('wrapperBilhetesVencedoresCliente');
    
    if(vencedores.length > 0) {
        bloqueioVencedorAtivo = true;
        box.style.display = 'block';

        titulo.innerHTML = vencedores.length > 1
            ? `🚨 🏆 DEU EMPATE! ${vencedores.length} GANHADORES NESTA RODADA! 🏆 🚨`
            : `🚨 🏆 PARABÉNS AO GRANDE GANHADOR! JOGO ENCERRADO! 🏆 🚨`;

        wrapper.innerHTML = "";
        vencedores.forEach(v => {
            let souEuGanhando = meusBiletesReservados.includes(parseInt(v.id));
            let bloco = document.createElement('div');
